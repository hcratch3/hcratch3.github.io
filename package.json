{
  "name": "scratch-gui",
  "version": "0.1.0",
  "description": "GraphicaL User Interface for creating and running Scratch 3.0 projects",
  "main": "./dist/scratch-gui.js",
  "scripts": {
    "build": "npm run clean && webpack --colors --bail",
    "clean": "rimraf ./build && mkdirp build && rimraf ./dist && mkdirp dist",
    "deploy": "gh-pages -d editor",
    "develop": "NODE_OPTIONS='--openssl-legacy-provider' gatsby develop",
    "prune": "./prune-gh-pages.sh",
    "i18n:push": "tx-push-src scratch-editor interface translations/en.json",
    "i18n:src": "rimraf ./translations/messages/src && babel src > tmp.js && rimraf tmp.js && build-i18n-src ./translations/messages/src ./translations/ && npm run i18n:push",
    "start": "webpack-dev-server",
    "test": "npm run test:lint && npm run test:unit && npm run build && npm run test:integration",
    "test:integration": "jest --runInBand test[\\\\/]integration",
    "test:lint": "eslint . --ext .js,.jsx",
    "test:unit": "jest test[\\\\/]unit",
    "test:smoke": "jest --runInBand test[\\\\/]smoke",
    "watch": "webpack --colors --watch"
  },
  "author": "Massachusetts Institute of Technology",
  "license": "BSD-3-Clause",
  "homepage": "https://github.com/LLK/scratch-gui#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/LLK/scratch-gui.git"
  },
  "dependencies": {
    "arraybuffer-loader": "^1.0.8",
    "autoprefixer": "^10.4.19",
    "base64-loader": "1.0.0",
    "bowser": "2.11.0",
    "classnames": "2.5.1",
    "computed-style-to-inline-style": "4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "core-js": "3.36.1",
    "css-loader": "^6.10.0",
    "es6-object-assign": "1.1.0",
    "file-loader": "6.2.0",
    "get-float-time-domain-data": "0.1.0",
    "get-user-media-promise": "1.1.4",
    "immutable": "4.3.5",
    "intl": "1.2.5",
    "js-base64": "3.7.7",
    "keymirror": "0.1.1",
    "lodash.bindall": "4.4.0",
    "lodash.debounce": "4.0.8",
    "lodash.defaultsdeep": "4.6.1",
    "lodash.omit": "4.5.0",
    "lodash.throttle": "4.1.1",
    "minilog": "3.1.0",
    "omggif": "1.0.10",
    "papaparse": "5.4.1",
    "postcss-import": "^16.1.0",
    "postcss-loader": "^8.1.1",
    "postcss-simple-vars": "^7.0.1",
    "prop-types": "^15.8.1",
    "query-string": "^9.0.0",
    "raw-loader": "^4.0.2",
    "react": "18.2.0",
    "react-contextmenu": "2.14.0",
    "react-dom": "18.2.0",
    "react-draggable": "4.4.6",
    "react-ga": "3.3.1",
    "react-intl": "6.6.3",
    "react-modal": "3.16.1",
    "react-popover": "0.5.10",
    "react-redux": "9.1.0",
    "react-responsive": "10.0.0",
    "react-style-proptype": "3.2.2",
    "react-tabs": "6.0.2",
    "react-tooltip": "5.26.3",
    "react-virtualized": "9.22.5",
    "redux": "5.0.1",
    "redux-throttle": "0.1.1",
    "scratch-audio": "1.0.58",
    "scratch-blocks": "1.1.63",
    "scratch-l10n": "3.18.80",
    "scratch-paint": "SheepTester/scratch-paint#16-9",
    "scratch-render": "1.0.75",
    "scratch-render-fonts": "1.0.27",
    "scratch-storage": "2.3.59",
    "scratch-svg-renderer": "SheepTester/scratch-svg-renderer#16-9",
    "scratch-vm": "hcratch3/scratch-vm#16-9",
    "startaudiocontext": "1.2.1",
    "style-loader": "^3.3.4",
    "text-encoding": "0.7.0",
    "to-style": "1.3.3",
    "wav-encoder": "1.3.0",
    "xhr": "2.6.0"
  },
  "peerDependencies": {
    "react": "^16.0.0",
    "react-dom": "^16.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.1",
    "@babel/core": "^7.24.3",
    "@babel/plugin-proposal-object-rest-spread": "^7.0.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-async-to-generator": "^7.24.1",
    "@babel/preset-env": "^7.24.3",
    "@babel/preset-react": "^7.24.1",
    "babel-core": "7.0.0-bridge.0",
    "babel-eslint": "^10.0.1",
    "babel-loader": "^9.1.3",
    "chromedriver": "123.0.0",
    "create-file-webpack": "^1.0.2",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "1.15.8",
    "eslint": "^8.57.0",
    "eslint-config-scratch": "^9.0.8",
    "eslint-import-resolver-webpack": "^0.13.8",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-react": "^7.34.1",
    "gh-pages": "github:rschamp/gh-pages#publish-branch-to-subfolder",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "mkdirp": "^3.0.1",
    "raf": "^3.4.1",
    "react-test-renderer": "18.2.0",
    "redux-mock-store": "^1.5.4",
    "rimraf": "^5.0.5",
    "selenium-webdriver": "4.18.1",
    "uglifyjs-webpack-plugin": "^2.2.0",
    "web-audio-test-api": "^0.5.2",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "jest": {
    "setupFiles": [
      "raf/polyfill",
      "<rootDir>/test/helpers/enzyme-setup.js"
    ],
    "testPathIgnorePatterns": [
      "src/test.js"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/test/__mocks__/fileMock.js",
      "\\.(css|less)$": "<rootDir>/test/__mocks__/styleMock.js",
      "editor-msgs(\\.js)?$": "<rootDir>/test/__mocks__/editor-msgs-mock.js"
    }
  }
}
